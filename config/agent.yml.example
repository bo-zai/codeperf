serverUrl: http://127.0.0.1:9095
uploadEnabled: true
appName: codeperf-demo-app
env: dev
buildInfoPath: /opt/codeperf/build-info.properties
targetPackages:
  - com.codeperf.demo
entry:
  method: POST
  path: /api/orders/report
slowSqlMs: 500
sampleMs: 10
mode: session
output: /opt/codeperf/perf-data.raw
